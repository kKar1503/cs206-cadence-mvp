// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model User {
    id        String    @id @default(cuid())
    name      String?
    email     String    @unique
    password  String
    image     String?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    listings              Listing[]
    reviewsReceived       Review[]       @relation("ReviewSeller")
    reviewsGiven          Review[]       @relation("ReviewBuyer")
    ordersBought          Order[]        @relation("OrderBuyer")
    ordersSold            Order[]        @relation("OrderSeller")
    favorites             Favorite[]
    messagesSent          Message[]      @relation("MessageSender")
    postalCode            String?
    latitude              Float?
    longitude             Float?

    conversationsStarted  Conversation[] @relation("ConversationUser1")
    conversationsReceived Conversation[] @relation("ConversationUser2")
    savedCards            SavedCard[]
    notifications         Notification[]
}

// WARNING: This model stores raw card details in plaintext.
// This is ONLY acceptable because the entire payment system is a fake/simulated
// prototype for a school project (CS206). All card credentials stored here are
// fake test data. In a real production system, you MUST use a PCI-compliant
// payment processor (e.g., Stripe) and NEVER store raw card numbers.
model SavedCard {
    id             String   @id @default(cuid())
    cardNumber     String   // Stored raw — fake/simulated payment only
    cardName       String   // Cardholder name
    expiryDate     String   // MM/YY format
    cardType       String   // "visa" or "mastercard"
    last4          String   // Last 4 digits for display

    user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId         String

    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@index([userId])
}

enum ListingType {
    VINYL
    CD
    CASSETTE
    MERCH
    EQUIPMENT
}

enum Condition {
    BRAND_NEW
    LIKE_NEW
    LIGHTLY_USED
    WELL_USED
    HEAVILY_USED
}

model Listing {
    id                    String       @id @default(cuid())
    title                 String
    artist                String
    description           String       @db.Text
    type                  ListingType
    condition             Condition
    price                 Float
    images                String       @db.Text  // JSON array of image URLs
    imageUrl              String?      // Deprecated, keeping for backward compatibility
    year                  Int?
    genre                 String?
    label                 String?

    // AI verification fields
    isVerified            Boolean      @default(false)
    verifiedByOfficial    Boolean      @default(false)
    authenticityScore     Float?       // 0-100 overall authenticity score from AI
    verificationSource    String?      // Organization that verified (e.g., "Discogs", "Vinyl Authenticators Inc.")

    // AI Insights - Authenticity breakdown
    labelMatchScore       Float?       // 0-100 score for label authenticity
    matrixNumberScore     Float?       // 0-100 score for matrix number verification
    typographyScore       Float?       // 0-100 score for typography matching
    serialRangeScore      Float?       // 0-100 score for serial range verification
    authenticityNotes     String?      @db.Text // AI-generated notes about authenticity

    // AI Insights - Condition breakdown
    conditionScore        Float?       // 0-100 overall condition score from AI
    vinylSurfaceScore     Float?       // 0-100 score for vinyl surface condition
    sleeveScore           Float?       // 0-100 score for sleeve/cover condition
    labelConditionScore   Float?       // 0-100 score for label condition
    edgesScore            Float?       // 0-100 score for edges/corners condition
    conditionNotes        String?      @db.Text // AI-generated notes about condition

    // AI Insights - Per-sub-score justifications (JSON)
    authenticityJustifications String?  @db.Text // JSON: { labelMatch, matrixNumber, typography, serialRange }
    conditionJustifications    String?  @db.Text // JSON: { surface, sleeve, label, edges }

    // Tracklist
    tracklist             String?      @db.Text // JSON: [{ side: "A", tracks: ["Track 1", ...] }, ...]

    // Promotion
    isPromoted            Boolean      @default(false)
    promotedUntil         DateTime?

    // Marketplace fields
    isSold                Boolean      @default(false)
    views                 Int          @default(0)

    // Price comparison fields
    priceLabel            String?      // "OVERPRICED", "FAIR", "UNDERPRICED"
    pricePercentage       Float?       // Percentage difference from market price (e.g., 15.5 for 15.5% overpriced)
    priceDataUpdated      DateTime?    // Date when price comparison data was last updated

    createdAt             DateTime     @default(now())
    updatedAt             DateTime     @updatedAt

    seller                User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
    sellerId              String
    review                Review?
    orders                Order[]
    favorites             Favorite[]
    conversations         Conversation[]
    platformPrices        PlatformPrice[]

    @@index([title])
    @@index([artist])
    @@index([type])
    @@index([sellerId])
}

// External platform pricing data for price comparison
model PlatformPrice {
    id          String   @id @default(cuid())
    platform    String   // e.g., "Discogs", "eBay", "Amazon"
    minPrice    Float?   // Minimum price found on platform
    maxPrice    Float?   // Maximum price found on platform
    avgPrice    Float?   // Average price (optional, used for single price points)
    priceLabel  String?  // "Fair", "Slightly High", "Optimal"
    currency    String   @default("USD")

    listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
    listingId   String

    updatedAt   DateTime @updatedAt
    createdAt   DateTime @default(now())

    @@index([listingId])
    @@index([platform])
}

// A review is left by a buyer (reviewer) about a seller (seller), tied to a specific listing
model Review {
    id          String   @id @default(cuid())
    rating      Int      // 1-5
    comment     String   @db.Text

    seller      User     @relation("ReviewSeller", fields: [sellerId], references: [id], onDelete: Cascade)
    sellerId    String

    reviewer    User     @relation("ReviewBuyer", fields: [reviewerId], references: [id], onDelete: Cascade)
    reviewerId  String

    listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
    listingId   String   @unique  // one review per listing transaction

    createdAt   DateTime @default(now())

    @@index([sellerId])
    @@index([reviewerId])
}

model Order {
    id          String   @id @default(cuid())
    orderNumber String   @unique

    buyer       User     @relation("OrderBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
    buyerId     String

    listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
    listingId   String

    seller      User     @relation("OrderSeller", fields: [sellerId], references: [id], onDelete: Cascade)
    sellerId    String

    amount      Float    // Total buyer pays (item + shipping + buyer fee)
    shippingCost       Float?
    platformFee        Float?   // Total platform fee (buyer + seller portions)
    buyerFee           Float?   // Fee charged to buyer (added to total)
    sellerFee          Float?   // Fee deducted from seller payout
    sellerPayout       Float?   // Amount seller receives (item price - seller fee)
    shippingAddress1   String?   // Street address line 1 (auto-filled from OneMap)
    shippingAddress2   String?   // Street address line 2 (optional)
    shippingFloor      String?   // Floor number (optional)
    shippingUnit       String?   // Unit number (optional)
    shippingPostalCode String?   // Singapore postal code
    shippingCountry    String?   @default("Singapore")
    status      String   @default("completed") // completed, pending, cancelled

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([buyerId])
    @@index([sellerId])
    @@index([listingId])
}

model Favorite {
    id        String   @id @default(cuid())

    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String

    listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
    listingId String

    createdAt DateTime @default(now())

    @@unique([userId, listingId]) // Prevent duplicate favorites
    @@index([userId])
    @@index([listingId])
}

// Conversation between two users about a specific listing
model Conversation {
    id             String    @id @default(cuid())

    user1          User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
    user1Id        String

    user2          User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
    user2Id        String

    listing        Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
    listingId      String    // Each conversation is tied to a specific listing

    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    messages       Message[]

    @@unique([user1Id, user2Id, listingId]) // Each pair of users can have one conversation per listing
    @@index([user1Id])
    @@index([user2Id])
    @@index([listingId])
}

// Individual message in a conversation
model Message {
    id             String       @id @default(cuid())
    content        String       @db.Text

    conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    conversationId String

    sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
    senderId       String

    isRead         Boolean      @default(false)

    createdAt      DateTime     @default(now())

    @@index([conversationId])
    @@index([senderId])
}

enum NotificationType {
    LISTING_SOLD
    ORDER_CONFIRMED
    FAVORITED_LISTING_SOLD
    LISTING_VERIFIED
    PRICE_CHANGED
    LISTING_UPDATED
    NEW_FAVORITE
}

model Notification {
    id        String           @id @default(cuid())
    type      NotificationType
    message   String
    isRead    Boolean          @default(false)

    user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String

    listingId String?
    orderId   String?

    createdAt DateTime         @default(now())

    @@index([userId, isRead])
    @@index([userId, createdAt])
}
